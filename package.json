{
  "name": "moovu-kasi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:customer": "node scripts/build-target.mjs customer",
    "build:driver": "node scripts/build-target.mjs driver",
    "start": "next start",
    "lint": "eslint",
    "test:dispatch": "node --test --experimental-strip-types src/lib/dispatch/dispatchPolicy.test.ts",
    "test:status-contracts": "node --test --experimental-strip-types src/lib/drivers/statusContract.test.ts",
    "sync:customer": "node scripts/capacitor-ios-target.mjs customer sync",
    "sync:driver": "node scripts/capacitor-ios-target.mjs driver sync",
    "copy:customer": "node scripts/capacitor-ios-target.mjs customer copy",
    "copy:driver": "node scripts/capacitor-ios-target.mjs driver copy",
    "open:customer": "node scripts/capacitor-ios-target.mjs customer open",
    "open:driver": "node scripts/capacitor-ios-target.mjs driver open",
    "archive:customer": "node scripts/capacitor-ios-target.mjs customer archive",
    "archive:driver": "node scripts/capacitor-ios-target.mjs driver archive",
    "ios:customer": "npm run build:customer && npm run sync:customer",
    "ios:driver": "npm run build:driver && npm run sync:driver",
    "ios:customer:add": "node scripts/capacitor-ios-target.mjs customer add",
    "ios:driver:add": "node scripts/capacitor-ios-target.mjs driver add",
    "ios:customer:open": "npm run open:customer",
    "ios:driver:open": "npm run open:driver",
    "ios:customer:doctor": "node scripts/capacitor-ios-target.mjs customer doctor",
    "ios:driver:doctor": "node scripts/capacitor-ios-target.mjs driver doctor"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.3",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/push-notifications": "^8.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
